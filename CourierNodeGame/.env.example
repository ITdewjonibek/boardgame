# Environment Variables Template

# Backend API
VITE_API_URL=http://localhost:3000/api

# Auth
VITE_AUTH_SECRET=your_secret_key_here

# Game Settings
VITE_GAME_TIME_LIMIT=120
VITE_GAME_TOTAL_LIGHTS=20
VITE_WAIT_CORRECT=5
VITE_WAIT_WRONG=10
VITE_BASE_BONUS=10000

# Feature Flags
VITE_ENABLE_BACKEND=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
